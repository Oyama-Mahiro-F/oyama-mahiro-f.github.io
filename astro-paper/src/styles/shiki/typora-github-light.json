{
  "name": "typora-github-light",
  "type": "light",
  "settings": [
    {
      "settings": {
        "foreground": "#24292f",
        "background": "#f6f8fa"
      }
    },
    {
      "name": "Comment",
      "scope": "comment",
      "settings": { "foreground": "#6a737d", "fontStyle": "italic" }
    },
    {
      "name": "Keyword",
      "scope": "keyword",
      "settings": { "foreground": "#d73a49" }
    },
    {
      "name": "Storage",
      "scope": "storage",
      "settings": { "foreground": "#d73a49" }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": { "foreground": "#032f62" }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": { "foreground": "#005cc5" }
    },
    {
      "name": "Function",
      "scope": "entity.name.function",
      "settings": { "foreground": "#6f42c1" }
    },
    {
      "name": "Class",
      "scope": "entity.name.type",
      "settings": { "foreground": "#6f42c1" }
    },
    {
      "name": "Support",
      "scope": "support.function, support.class",
      "settings": { "foreground": "#6f42c1" }
    },
    {
      "name": "Variable",
      "scope": "variable",
      "settings": { "foreground": "#e36209" }
    },
    {
      "name": "Tag",
      "scope": "entity.name.tag",
      "settings": { "foreground": "#22863a" }
    },
    {
      "name": "Attribute",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#6f42c1" }
    },
    {
      "name": "Inserted",
      "scope": "markup.inserted",
      "settings": { "foreground": "#22863a", "background": "#f0fff4" }
    },
    {
      "name": "Deleted",
      "scope": "markup.deleted",
      "settings": { "foreground": "#b31d28", "background": "#ffeef0" }
    },
    {
      "name": "Line Number",
      "scope": "gutter",
      "settings": { "foreground": "#959da5" }
    }
  ]
}
