{
  "name": "typora-github-dark",
  "type": "dark",
  "settings": [
    {
      "settings": {
        "foreground": "#e6edf3",
        "background": "#0d1117"
      }
    },
    {
      "name": "Comment",
      "scope": "comment",
      "settings": { "foreground": "#8b949e", "fontStyle": "italic" }
    },
    {
      "name": "Keyword",
      "scope": "keyword",
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "name": "Storage",
      "scope": "storage",
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": { "foreground": "#a5d6ff" }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": { "foreground": "#79c0ff" }
    },
    {
      "name": "Function",
      "scope": "entity.name.function",
      "settings": { "foreground": "#d2a8ff" }
    },
    {
      "name": "Class",
      "scope": "entity.name.type",
      "settings": { "foreground": "#d2a8ff" }
    },
    {
      "name": "Support",
      "scope": "support.function, support.class",
      "settings": { "foreground": "#d2a8ff" }
    },
    {
      "name": "Variable",
      "scope": "variable",
      "settings": { "foreground": "#ffa657" }
    },
    {
      "name": "Tag",
      "scope": "entity.name.tag",
      "settings": { "foreground": "#7ee787" }
    },
    {
      "name": "Attribute",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#d2a8ff" }
    },
    {
      "name": "Inserted",
      "scope": "markup.inserted",
      "settings": { "foreground": "#aff5b4", "background": "#033a16" }
    },
    {
      "name": "Deleted",
      "scope": "markup.deleted",
      "settings": { "foreground": "#ffdcd7", "background": "#490202" }
    },
    {
      "name": "Line Number",
      "scope": "gutter",
      "settings": { "foreground": "#6e7681" }
    }
  ]
}
