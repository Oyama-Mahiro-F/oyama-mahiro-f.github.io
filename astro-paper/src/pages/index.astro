---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");

// Merge featured + recent for a single list if no featured section
const displayPosts = featuredPosts.length > 0
  ? { featured: featuredPosts, recent: recentPosts.slice(0, postsConfig.perIndex) }
  : { featured: [], recent: recentPosts.slice(0, postsConfig.perIndex) };
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
  >
    <!-- Gradient Hero -->
    <section
      id="hero"
      class="relative overflow-hidden"
      style="background: linear-gradient(135deg, #3b5ccc 0%, #6b8cff 50%, #a78bfa 100%); animation: brandPulse 4s ease-in-out infinite;"
    >
      <div class="app-layout py-16 text-center text-white sm:py-20">
        <h1 class="text-3xl font-extrabold tracking-tight sm:text-5xl" style="color: #fff;">
          你好 👋
        </h1>
        <p class="mx-auto mt-4 max-w-lg text-base leading-relaxed opacity-85 sm:text-lg">
          欢迎来到我的技术博客。这里记录我的编程学习、项目经验和思考。
        </p>
        <div class="mt-6 flex items-center justify-center gap-4">
          <LinkButton
            href={getRelativeLocaleUrl(locale, "posts")}
            class="rounded-full bg-white/15 px-5 py-2 text-sm font-medium text-white transition hover:bg-white/25"
          >
            查看文章
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
          <LinkButton
            href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
            class="text-white/60 transition hover:text-white/90"
            aria-label="RSS Feed"
            title="RSS Feed"
          >
            <IconRss
              width={20}
              height={20}
              class="stroke-current stroke-3 rtl:-rotate-90 inline-block"
            />
            <span class="sr-only">RSS Feed</span>
          </LinkButton>
        </div>
      </div>
    </section>

    <!-- Post listing -->
    <div class="app-layout">
      {
        displayPosts.featured.length > 0 && (
          <section
            id="featured"
            class:list={[
              "pt-12 pb-6",
              { "border-border border-b": displayPosts.recent.length > 0 },
            ]}
          >
            <h2 class="text-2xl font-semibold tracking-wide">
              {t.home.featured}
            </h2>
            <ul>
              {displayPosts.featured.map((data, i) => (
                <Card {...data} index={i} />
              ))}
            </ul>
          </section>
        )
      }

      {
        displayPosts.recent.length > 0 && (
          <section id="recent-posts" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">
              {t.home.recentPosts}
            </h2>
            <ul>
              {displayPosts.recent.map((data, i) => (
                <Card {...data} index={i} />
              ))}
            </ul>
          </section>
        )
      }

      <div class="my-8 text-center">
        <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
          {t.home.allPosts}
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  @keyframes brandPulse {
    0%, 100% { box-shadow: 0 4px 24px rgba(59,92,204,.15); }
    50% { box-shadow: 0 8px 40px rgba(59,92,204,.3); }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
